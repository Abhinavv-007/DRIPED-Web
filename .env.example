# ============================================================
# Driped Web \u2014 environment template
# ------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values.
# Values beginning with NEXT_PUBLIC_ are embedded in the
# client bundle at build time \u2014 never put secrets there.
# ============================================================

# ---- API / Worker ----
# Production: https://api.driped.in
# Local dev : http://localhost:8787   (wrangler dev)
NEXT_PUBLIC_WORKER_URL=https://api.driped.in

# Optional alias used by some internal scripts / CI jobs
WORKER_API_BASE_URL=https://api.driped.in

# ---- Firebase (web client config) ----
NEXT_PUBLIC_FIREBASE_API_KEY=replace_me
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=driped-login.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=driped-login
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=driped-login.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_me
NEXT_PUBLIC_FIREBASE_APP_ID=replace_me

# ---- Optional: Cloudflare deploy (only used by CI, never committed) ----
CLOUDFLARE_ACCOUNT_ID=replace_me
CLOUDFLARE_API_TOKEN=replace_me

# ---- Optional: Google Analytics / Sentry (if you wire them) ----
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_SENTRY_DSN=
