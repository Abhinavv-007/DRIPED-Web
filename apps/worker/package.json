{
  "name": "driped-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run migrate:local && wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "migrate": "wrangler d1 execute driped-db --file=src/db/schema.sql",
    "migrate:local": "wrangler d1 execute driped-db --local --file=src/db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.60.0"
  }
}
